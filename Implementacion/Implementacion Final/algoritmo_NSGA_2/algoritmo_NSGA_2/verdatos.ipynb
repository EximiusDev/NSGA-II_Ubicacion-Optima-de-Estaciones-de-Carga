   "source": [
    "import geopandas as gpd\n",
    "import fiona\n",
    "\n",
    "ruta = \"dataset_final.gpkg\"\n",
    "\n",
    "# Ver capas disponibles\n",
    "print(\"Capas disponibles:\", fiona.listlayers(ruta))\n",
    "\n",
    "# Leer una capa\n",
    "gdf = gpd.read_file(ruta)\n",
    "\n",
    "# Mostrar información básica\n",
    "print(gdf.info())\n",
    "print(gdf.head())\n",
    "\n",
    "# Graficar\n",
    "gdf.plot()\n"
   ]
  }
